# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
KIMI_API_KEY="MY_KIMI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase public connection settings for frontend.
# Get these from Project Settings -> API in Supabase dashboard.
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# Local dev: browser calls http://localhost:3000/supabase-proxy instead of *.supabase.co (helps when direct TLS is blocked).
# VITE_SUPABASE_DEV_PROXY="true"
# Must be listed in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs.
# VITE_AUTH_REDIRECT_URL="http://localhost:3000"

# Optional. Set to true to skip Vite dev-only Content-Security-Policy headers (default allows unsafe-eval for HMR).
# VITE_STRICT_DEV_CSP=true

# Volcengine speech-to-text for dream journal.
VOLCENGINE_ARK_API_KEY="YOUR_ARK_API_KEY"
# Speech model for Ark chat/completions + input_audio (NOT doubao-seed-2-0-pro, which has no audio input).
# Activate in Ark console: https://console.volcengine.com/ark
VOLCENGINE_ARK_SPEECH_MODEL="doubao-seed-2-0-mini-260428"
# Optional dedicated openspeech credentials from https://console.volcengine.com/speech/app
# App ID + Access Token from your speech app (e.g. shimei / 6485592067).
# VOLCENGINE_ASR_APP_KEY="6485592067"
# VOLCENGINE_ASR_ACCESS_KEY="YOUR_SPEECH_ACCESS_TOKEN"
# ASR 2.0 streaming (hourly billing): volc.seedasr.sauc.duration
# ASR 2.0 streaming (concurrent billing): volc.seedasr.sauc.concurrent
# VOLCENGINE_ASR_RESOURCE_ID="volc.seedasr.sauc.duration"
VITE_VOLCENGINE_SPEECH="true"
